# ── Retrieval Pipeline Configuration ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# All variables are optional — the defaults shown here are used when a
# variable is absent from both this file and the shell environment.

# ── Chunking ────────────────────────────────────────────────────────────────
# Maximum characters per document chunk
CHUNK_SIZE=300

# Overlap in characters between consecutive chunks
CHUNK_OVERLAP=50

# ── Models ──────────────────────────────────────────────────────────────────
# HuggingFace model ID for bi-encoder embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# HuggingFace model ID for cross-encoder reranking
RERANKER_MODEL=BAAI/bge-reranker-base

# ── Vector Store ────────────────────────────────────────────────────────────
# Directory where Chroma persists its data
CHROMA_DIR=./chroma_store

# Chroma collection name
COLLECTION_NAME=generic_docs

# ── Retrieval ────────────────────────────────────────────────────────────────
# Number of candidates retrieved by the bi-encoder
TOP_K=6

# Number of results kept after cross-encoder reranking (must be <= TOP_K)
TOP_N=3

# ── Hardware ────────────────────────────────────────────────────────────────
# PyTorch device: cpu | cuda | mps
DEVICE=cpu

# ── LLM (Groq) ──────────────────────────────────────────────────────────────
# Groq API key — obtain from https://console.groq.com
GROQ_API_KEY=API_KEY_HERE

# Groq model to use for generation
GROQ_MODEL=llama-3.1-8b-instant

# Maximum tokens to generate in the LLM response
LLM_MAX_TOKENS=512

# Temperature for generation (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.0

# ── Data Source ──────────────────────────────────────────────────────────────
# Path to the document source used by the CLI entry point.
# Accepts a file path, directory path, or HTTP(S) URL.
# This is read by PipelineConfig — setting it here is enough; no shell
# export required.
PIPELINE_SOURCE=./dataset/samplee.pdf

# ── Agent Tools ──────────────────────────────────────────────────────────────
# Tavily Search API key — obtain from https://tavily.com
# Required for the web_search tool
TAVILY_API_KEY=API_KEY_HERE

# SMTP configuration — required for the send_email tool
# Example values below are for Gmail with an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=user@gmail.com
SMTP_PASSWORD=API_KEY_HERE

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=API_KEY_HERE
LANGSMITH_PROJECT="new"